# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cấu hình Token bảo mật (JSON string) cho các kênh Facebook Page
# META_PAGE_TOKENS_JSON='{"PAGE_ID_1": "TOKEN_1"}'
META_PAGE_TOKENS_JSON='{"123456789": "fb_mock_token_for_page"}'
META_GRAPH_API_VERSION="v20.0"

# Cấu hình Token bảo mật (JSON string) cho các kênh Zalo Official Account (OA)
# ZALO_OA_TOKENS_JSON='{"OA_ID_1": "TOKEN_1"}'
ZALO_OA_TOKENS_JSON='{"987654321": "zalo_mock_token_for_oa"}'

# Khóa bảo mật kích hoạt cron job / trigger đồng bộ định kỳ tự động từ Cloud Scheduler
CRON_SECRET="default_cron_secret_12345"

# Danh sách email của các ADMIN được quyền quản trị hệ thống (cách nhau bằng dấu phẩy)
ADMIN_EMAILS="09.levanbinh2003@gmail.com"

# ==========================================
# CẤU HÌNH TRIỂN KHAI VPS (1-CLICK DEPLOY)
# ==========================================
# IP hoặc domain của VPS
DEPLOY_HOST="123.45.67.89"
# Cổng SSH của VPS (mặc định là 22)
DEPLOY_PORT="22"
# Tài khoản SSH (thường là root)
DEPLOY_USER="root"
# Mật khẩu SSH (để trống nếu dùng SSH Key)
DEPLOY_PASSWORD="your_vps_ssh_password"
# Đường dẫn tới SSH Private Key ở local (để trống nếu dùng mật khẩu)
# Ví dụ trên Windows: "C:/Users/Admin/.ssh/id_rsa"
DEPLOY_KEY_PATH=""
# Thư mục triển khai ứng dụng trên VPS
DEPLOY_PATH="/var/www/ft-social-dashboard"
