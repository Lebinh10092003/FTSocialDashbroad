# ==========================================
# CẤU HÌNH ỨNG DỤNG
# ==========================================

# Cổng nội bộ của ứng dụng Node.js trên VPS.
# Nginx sẽ chuyển tiếp workspace.fermat.vn tới cổng này.
PORT="5500"

# Tên miền công khai của hệ thống, không thêm dấu / ở cuối.
APP_URL="https://workspace.fermat.vn"

# GEMINI_API_KEY: dùng cho các chức năng Gemini AI nếu được bật.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Cấu hình Token bảo mật (JSON string) cho các kênh Facebook Page.
# META_PAGE_TOKENS_JSON='{"PAGE_ID_1":"TOKEN_1"}'
META_PAGE_TOKENS_JSON='{}'
META_GRAPH_API_VERSION="v25.0"

# Cấu hình Token bảo mật (JSON string) cho các kênh Zalo Official Account.
# ZALO_OA_TOKENS_JSON='{"OA_ID_1":"TOKEN_1"}'
ZALO_OA_TOKENS_JSON='{}'

# Khóa bảo mật kích hoạt cron job / trigger đồng bộ định kỳ.
CRON_SECRET="replace_with_a_long_random_value"

# Danh sách email ADMIN, phân tách bằng dấu phẩy.
ADMIN_EMAILS="admin@ftsocial.com"

# Chỉ cho phép các origin dưới đây gọi API từ trình duyệt.
CORS_ORIGIN="https://workspace.fermat.vn"

# ==========================================
# CẤU HÌNH TRIỂN KHAI VPS - CHỈ DÙNG Ở MÁY LOCAL
# Các biến DEPLOY_* được loại khỏi file .env gửi lên VPS.
# ==========================================

# Tên miền hiển thị sau khi deploy và dùng để health check công khai.
DEPLOY_PUBLIC_URL="https://workspace.fermat.vn"

# IP hoặc domain SSH của VPS.
DEPLOY_HOST="123.45.67.89"
DEPLOY_PORT="22"
DEPLOY_USER="root"

# Chỉ dùng một trong hai phương thức: mật khẩu hoặc SSH Private Key.
DEPLOY_PASSWORD="your_vps_ssh_password"
# Ví dụ Windows: C:/Users/Admin/.ssh/id_rsa
DEPLOY_KEY_PATH=""

DEPLOY_PATH="/var/www/ft-social-dashboard"
PM2_APP_NAME="ft-social-dashboard"
