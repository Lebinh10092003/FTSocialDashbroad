DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,workspace.fermat.vn
# Local: leave blank to use backend/db.sqlite3. Production: set a durable path
# outside the release directory, for example /var/lib/ft-workspace/data/workspace.sqlite3.
DJANGO_DB_PATH=
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://workspace.fermat.vn
ADMIN_EMAILS=admin@ftsocial.com
BOOTSTRAP_ADMIN_EMAIL=admin@ftsocial.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-initial-password
GOOGLE_SERVICE_ACCOUNT_JSON=
META_PAGE_TOKENS_JSON={}
META_GRAPH_API_VERSION=v25.0
ZALO_OA_TOKENS_JSON={}
CRON_SECRET=replace-with-a-long-random-value

# Temporary social dashboard token (keep this value only in backend/.env).
CURRENT_FACEBOOK_ACCESS_TOKEN=
CURRENT_FACEBOOK_TOKEN_TTL_DAYS=53
CURRENT_FACEBOOK_PAGE_ID=
CURRENT_FACEBOOK_PAGE_NAME=Facebook
